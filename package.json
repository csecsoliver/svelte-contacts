{
  "name": "svelte-contacts",
  "version": "0.0.1",
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/bun": "^1.3.13",
    "svelte": "^5.55.2",
    "svelte-adapter-bun": "^1.0.1",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "vite": "^8.0.7"
  },
  "private": true,
  "scripts": {
    "dev": "bun x --bun vite dev",
    "build": "bun x --bun vite build",
    "preview": "bun ./build/index.js",
    "start": "bun x --bun vite build && bun ./build/index.js",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "trustedDependencies": [
    "core-js"
  ],
  "type": "module"
}
